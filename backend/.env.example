# Copy this file to ".env" and fill in your own values.
# Get a free TMDB API key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# --- Optional ---
# Port the Node backend listens on (default 5001)
# PORT=5001

# Port the Python recommender service listens on (default 8000)
# PYTHON_SERVICE_PORT=8000

# Use an externally-managed recommender service instead of auto-spawning one
# PYTHON_SERVICE_URL=http://127.0.0.1:8000

# Force a specific Python interpreter for the recommender service
# PYTHON_PATH=C:\path\to\python.exe
